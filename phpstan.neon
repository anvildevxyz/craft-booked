parameters:
    level: 5
    paths:
        - src
    excludePaths:
        - src/templates/*
        - src/migrations/*
        - src/web/*
        - src/translations/*
    tmpDir: .phpstan
    treatPhpDocTypesAsCertain: false
    bootstrapFiles:
        - ../../vendor/autoload.php
        - ../../vendor/craftcms/cms/bootstrap/console.php
        - stubs/phpstan-bootstrap.php
    ignoreErrors:
        # Common patterns for Craft CMS plugins
        - '#Cannot access offset .+ on mixed#'
        - '#Cannot cast mixed to#'
        # Controller return types - asJson() and renderTemplate() return craft\web\Response
        - '#Method .+ should return craft\\web\\Response but returns yii\\web\\Response#'
        # Service extra queries return ElementInterface but are narrowed to ServiceExtra
        - '#Method .+ServiceExtraService::get.*\(\) should return array<anvildev\\booked\\elements\\ServiceExtra> but returns array<craft\\base\\ElementInterface>#'
        # ActiveRecord find()->one() returns array|ActiveRecord — we know the concrete type
        - '#Cannot access property \$\w+ on array\|yii\\db\\ActiveRecord#'
        # Element::afterPopulate() and afterFind() are protected methods PHPStan may not resolve
        - '#Call to an undefined static method craft\\base\\Element::(afterPopulate|afterFind)\(\)#'
        # Settings model uses dynamic properties for calendar/integration credentials
        - '#Access to an undefined property anvildev\\booked\\models\\Settings::\$\w+#'
        # getSalesForPurchasable() expects PurchasableInterface, but Reservation uses the shim when Commerce is absent
        - '#Parameter .+ of method .+getSalesForPurchasable\(\) expects .+PurchasableInterface, .+ given#'
        # ReservationExtraRecord accessor
        - '#Access to an undefined property anvildev\\booked\\records\\ReservationExtraRecord::\$extra#'
        # ServiceExtra::$sortOrder is set dynamically in reorder actions
        - '#Access to an undefined property anvildev\\booked\\elements\\ServiceExtra::\$sortOrder#'
        # Employee eagerLoadingMap accesses $el->userId/$el->locationId on ElementInterface
        - '#Access to an undefined property craft\\base\\ElementInterface::\$(userId|locationId)#'
        # Guzzle response->getBody() on mixed in calendar providers
        - '#Cannot call method getBody\(\) on mixed#'
        # WebhookRecord::handlesEvent() called on ActiveRecord query result
        - '#Cannot call method handlesEvent\(\) on array\|yii\\db\\ActiveRecord#'
        # ReservationInterface::getFirstErrors() — exists on both Element and Model implementations
        - '#Call to an undefined method anvildev\\booked\\contracts\\ReservationInterface::getFirstErrors\(\)#'
        # ElementQuery::one() returns array|ElementInterface, but we access concrete element properties
        - '#Cannot access property \$\w+ on array\|craft\\base\\ElementInterface#'
        - '#Cannot call method \w+\(\) on array\|craft\\base\\ElementInterface#'
        # ReservationInterface property access — both implementations have public properties,
        # but PHPStan can't resolve @property on interfaces with reportMagicProperties: true
        - '#Access to an undefined property anvildev\\booked\\contracts\\ReservationInterface::\$\w+#'
        # ActiveRecord find()->all() returns array<array|ActiveRecord>, concrete type known
        - '#should return array<anvildev\\booked\\records\\\w+> but returns array<array\|yii\\db\\ActiveRecord>#'
        - '#Parameter .+ expects anvildev\\booked\\records\\WaitlistRecord, array\|yii\\db\\ActiveRecord given#'
        # ActiveRecord methods called on query results (getTotalPrice, etc.)
        - '#Cannot call method \w+\(\) on array\|yii\\db\\ActiveRecord#'
        # BookingDataController accesses Service properties on ElementInterface
        - '#Access to an undefined property craft\\base\\ElementInterface::\$\w+#'
        # ReservationModel internal property type
        - '#Property .+ReservationModel::\$_service .+ does not accept array\|craft\\base\\ElementInterface\|null#'
        # ReservationModelQuery maps ActiveRecord to Model
        - '#Parameter .+ of function array_map expects .+, Closure\(anvildev\\booked\\records\\ReservationRecord\).+ given#'
        # BookingVariable::services() returns ServiceQuery
        - '#Method .+BookingVariable::services\(\) should return .+ServiceQuery but returns craft\\elements\\db\\ElementQuery#'
        # CommerceService expects Reservation element, receives ReservationInterface
        - '#Parameter .+ expects anvildev\\booked\\elements\\Reservation, anvildev\\booked\\contracts\\ReservationInterface given#'
        # Commerce Orders service methods not available without Commerce installed
        - '#Call to an undefined method craft\\commerce\\services\\Orders::saveOrder\(\)#'
        # yii2-redis is an optional dependency for MutexFactory
        - '#Instantiated class yii\\redis\\Mutex not found#'
        - '#Method .+MutexFactory::createRedisMutex\(\) should return yii\\mutex\\Mutex but returns yii\\redis\\Mutex#'
        # Condition rules call custom query methods via ElementQueryInterface (Craft CMS pattern)
        - '#Call to an undefined method craft\\elements\\db\\ElementQueryInterface::\w+\(\)#'
        # BaseNumberConditionRule::queryParamValue() not resolved by PHPStan
        - '#Call to an undefined method anvildev\\booked\\elements\\conditions\\Service\w+ConditionRule::queryParamValue\(\)#'
        # Craft's AssetManager::getPublishedUrl() has a $publish param not present in Yii2 stub
        - '#Method yii\\web\\AssetManager::getPublishedUrl\(\) invoked with 2 parameters, 1 required#'

    # Rules for stricter code
    checkFunctionNameCase: true
    reportMagicMethods: true
    reportMagicProperties: true
    checkExplicitMixed: true

includes:
    - ../../vendor/craftcms/phpstan/phpstan.neon
