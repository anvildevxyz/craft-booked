{
  "name": "@anvildev/booked-wizard",
  "version": "1.3.0-dev",
  "description": "Headless booking wizard core + zero-dependency vanilla renderer for the Booked Craft CMS plugin.",
  "license": "proprietary",
  "type": "module",
  "private": true,
  "exports": {
    "./core": {
      "import": "./dist/booked-wizard-core.esm.js",
      "require": "./dist/booked-wizard-core.cjs"
    }
  },
  "files": [
    "dist",
    "src/web/js/core"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "size": "node scripts/build.mjs --size",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "vitest": "^2.1.0"
  }
}
