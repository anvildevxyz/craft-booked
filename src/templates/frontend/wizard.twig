{#
/**
 * Booked Wizard Template
 *
 * A fully configurable booking wizard that guides users through the booking process.
 *
 * FLOW:
 * -----
 * Step 1: Select Service
 * Step 2: Select Location (skipped if 0 or 1 locations exist)
 * Step 3: Select Employee (skipped if only 1 employee available)
 * Step 4: Select Date & Time
 * Step 5: Enter Customer Info
 * Step 6: Review & Confirm
 * Step 7: Success
 *
 * USAGE:
 * ------
 * Include this template in your Twig templates:
 *
 *   {% include 'booked/frontend/wizard' %}
 *
 * Or with custom configuration:
 *
 *   {% include 'booked/frontend/wizard' with {
 *       labels: {
 *           stepService: 'Choose Service',
 *           stepLocation: 'Location',
 *       },
 *       requirePhone: true,
 *       showNotes: false,
 *   } %}
 *
 * CONFIGURATION VARIABLES:
 * ------------------------
 *
 * LABELS (labels object):
 * All text labels can be customized. Default values are in German.
 *
 *   labels.stepService          - Step indicator: Service (default: "1. Service")
 *   labels.stepLocation         - Step indicator: Location (default: "2. Ort")
 *   labels.stepEmployee         - Step indicator: Employee (default: "3. Mitarbeiter")
 *   labels.stepDateTime         - Step indicator: Date & Time (default: "Datum & Zeit")
 *   labels.stepInfo             - Step indicator: Customer info (default: "Info")
 *   labels.stepConfirm          - Step indicator: Confirmation (default: "Bestätigung")
 *
 *   labels.selectService        - Service selection heading (default: "Wählen Sie eine Dienstleistung")
 *   labels.selectLocation       - Location selection heading (default: "Wählen Sie einen Standort")
 *   labels.selectEmployee       - Employee selection heading (default: "Wählen Sie einen Mitarbeiter")
 *   labels.selectDateTime       - Date/time selection heading (default: "Wählen Sie Datum und Zeit")
 *   labels.enterInfo            - Customer info heading (default: "Ihre Informationen")
 *   labels.confirmBooking       - Confirmation heading (default: "Buchung bestätigen")
 *
 *   labels.noServices           - No services message title (default: "Keine Services verfügbar")
 *   labels.noServicesDesc       - No services message description
 *   labels.noSchedules          - No availability configured title (default: "Keine Verfügbarkeit konfiguriert")
 *   labels.noSchedulesDesc      - No availability configured description
 *   labels.noEmployees          - No employees message title (default: "Keine Mitarbeiter verfügbar")
 *   labels.noEmployeesDesc      - No employees message description
 *   labels.noSlots              - No slots message (default: "Keine freien Termine an diesem Tag.")
 *
 *   labels.anyEmployee          - "Any available" option title (default: "Beliebig")
 *   labels.anyEmployeeDesc      - "Any available" option description (default: "Erster verfügbarer Mitarbeiter")
 *   labels.firstAvailable       - First available label in summary (default: "Erster Verfügbarer")
 *
 *   labels.fieldName            - Name field label (default: "Name")
 *   labels.fieldEmail           - Email field label (default: "E-Mail")
 *   labels.fieldPhone           - Phone field label (default: "Telefon")
 *   labels.fieldNotes           - Notes field label (default: "Notizen")
 *
 *   labels.summaryService       - Summary: Service label (default: "Dienstleistung")
 *   labels.summaryLocation      - Summary: Location label (default: "Ort")
 *   labels.summaryEmployee      - Summary: Employee label (default: "Mitarbeiter")
 *   labels.summaryDate          - Summary: Date label (default: "Datum")
 *   labels.summaryTime          - Summary: Time label (default: "Zeit")
 *   labels.summaryQuantity      - Summary: Quantity label (default: "Anzahl Personen")
 *   labels.summaryName          - Summary: Name label (default: "Name")
 *   labels.summaryEmail         - Summary: Email label (default: "E-Mail")
 *
 *   labels.btnBack              - Back button (default: "Zurück")
 *   labels.btnNext              - Next button (default: "Weiter")
 *   labels.btnBook              - Book button (default: "Jetzt buchen")
 *   labels.btnProcessing        - Processing button (default: "Wird bearbeitet...")
 *   labels.btnNewBooking        - New booking button (default: "Neue Buchung erstellen")
 *   labels.btnHome              - Home button (default: "Zur Startseite")
 *
 *   labels.successTitle         - Success heading (default: "Buchung erfolgreich!")
 *   labels.successMessage       - Success message (default: "Ihre Buchung wurde erfolgreich erstellt.")
 *   labels.successStatus        - Success: Status label (default: "Status")
 *   labels.successBookingId     - Success: Booking ID label (default: "Buchungs-ID")
 *   labels.successAppointment   - Success: Appointment label (default: "Termin")
 *   labels.successNextSteps     - Success: Next steps heading (default: "Nächste Schritte:")
 *   labels.successEmailNote     - Success: Email note (default: "Sie erhalten in Kürze eine Bestätigungs-E-Mail...")
 *   labels.statusConfirmed      - Status: Confirmed (default: "Bestätigt")
 *
 *   labels.durationUnit         - Duration unit (default: "min")
 *   labels.currencySymbol       - Currency symbol (default: from plugin settings or Commerce)
 *
 * BEHAVIOR OPTIONS:
 *
 *   requirePhone                - Whether phone field is required (default: false)
 *   showNotes                   - Whether to show notes field (default: true)
 *   showPrice                   - Whether to show price on service cards (default: true)
 *   showDuration                - Whether to show duration on service cards (default: true)
 *   showEmployeeBio             - Whether to show employee bio (default: true)
 *   showStepIndicator           - Whether to show step indicator (default: true)
 *   defaultQuantity             - Default booking quantity (default: 1)
 *   homeUrl                     - URL for "Home" button (default: "/")
 *
 * CSS CLASSES (for custom styling):
 *
 *   cssPrefix                   - Prefix for all CSS classes (default: "booked")
 *   cssWrapperClass             - Additional wrapper class (default: "")
 *   customStyles                - Object of CSS custom properties to override design tokens (default: {})
 *                                  Example: { '--bk-black': '#1e3a5f', '--bk-white': '#f8fafc' }
 *                                  Available tokens: --bk-black, --bk-white, --bk-dark, --bk-hover,
 *                                  --bk-muted, --bk-placeholder, --bk-disabled, --bk-border-light,
 *                                  --bk-bg-light, --bk-bg-lighter, --bk-bg-soft, --bk-red, --bk-green
 *
 */
#}

