{#
/**
 * Account Portal Layout
 * 
 * Base layout for the customer account portal.
 */
#}

{% extends "_layout" %}

{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedAsset") %}

{% set bodyClass = bodyClass is defined ? bodyClass : 'page-account' %}

{% block content %}
<main id="main" class="main-content" role="main" tabindex="0">
    <div class="booked-wizard">

        {% if craft.app.session.hasFlash('notice') %}
            <div class="booked-flash">
                <p>{{ craft.app.session.getFlash('notice') }}</p>
            </div>
        {% endif %}

        {% if craft.app.session.hasFlash('error') %}
            <div class="booked-flash flash-error">
                <p>{{ craft.app.session.getFlash('error') }}</p>
            </div>
        {% endif %}

        <nav class="booked-account-nav">
            <ul>
                <li>
                    <a href="{{ url('booked/account') }}" class="{% if currentPage == 'dashboard' %}active{% endif %}">
                        {{ 'account.dashboard'|t('booked') }}
                    </a>
                </li>
                <li>
                    <a href="{{ url('booked/account/upcoming') }}" class="{% if currentPage == 'upcoming' %}active{% endif %}">
                        {{ 'account.upcoming'|t('booked') }}
                    </a>
                </li>
                <li>
                    <a href="{{ url('booked/account/past') }}" class="{% if currentPage == 'past' %}active{% endif %}">
                        {{ 'account.past'|t('booked') }}
                    </a>
                </li>
                <li>
                    <a href="{{ url('booked/account/bookings') }}" class="{% if currentPage == 'all' %}active{% endif %}">
                        {{ 'account.allBookings'|t('booked') }}
                    </a>
                </li>
            </ul>
        </nav>

        <div class="booked-account-header">
            <h3>{% block pageTitle %}{{ 'account.myAccount'|t('booked') }}{% endblock %}</h3>
            <p>{{ 'Welcome, {name}'|t('booked', { name: user.friendlyName }) }}</p>
        </div>

        {% block accountContent %}{% endblock %}
    </div>
</main>
{% endblock %}
