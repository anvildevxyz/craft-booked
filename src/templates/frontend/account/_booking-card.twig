{#
/**
 * Booking Card Partial
 *
 * Displays a single booking in the account portal.
 *
 * Variables:
 * - booking: The reservation element
 * - compact: Boolean - if true, shows a compact version (default: false)
 */
#}

{% set compact = compact ?? false %}
{% set isCancelled = booking.status == 'cancelled' %}

<div class="booked-booking-card{% if compact %} card-compact{% endif %}{% if isCancelled %} card-cancelled{% endif %}">
    <div class="booked-card-stripe stripe-{{ booking.status }}"></div>

    <div class="booked-booking-card-body">
        <div class="booked-booking-card-top">
            <p class="booked-booking-service">
                {% if booking.service %}{{ booking.service.title }}{% else %}{{ 'element.booking'|t('booked') }}{% endif %}
            </p>
            <span class="booked-badge badge-{{ booking.status }}">
                {{ booking.getStatusLabel() }}
            </span>
        </div>

        <p class="booked-booking-datetime">
            {{ booking.getFormattedDateTime() }}
        </p>

        <div class="booked-booking-card-meta">
            {% if booking.employee %}
                <span class="booked-booking-meta-tag">{{ booking.employee.title }}</span>
            {% endif %}
            {% if booking.location %}
                <span class="booked-booking-meta-tag">{{ booking.location.title }}</span>
            {% endif %}
            {% if booking.quantity > 1 %}
                <span class="booked-booking-meta-tag">{{ booking.quantity }}×</span>
            {% endif %}
        </div>

        {% if not compact %}
            <div class="booked-booking-actions">
                <a href="{{ url('booked/account/' ~ booking.id) }}" class="booked-btn">
                    {{ 'labels.view'|t('booked') }}
                </a>
                {% if booking.canBeCancelled() and not isCancelled %}
                    <form method="post" action="" class="inline-block">
                        {{ csrfInput() }}
                        {{ actionInput('booked/account/cancel') }}
                        {{ hiddenInput('id', booking.id) }}
                        {{ redirectInput(craft.app.request.url) }}
                        <button
                            type="submit"
                            onclick="return confirm('{{ 'account.cancelConfirm'|t('booked')|e('js') }}')"
                            class="booked-btn booked-btn-danger">
                            {{ 'labels.cancel'|t('booked') }}
                        </button>
                    </form>
                {% endif %}
            </div>
        {% endif %}
    </div>
</div>
