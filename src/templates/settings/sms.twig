	{# Config for notification-settings.js #}
	{% js %}
	window.BookedNotificationSettings = {
	            toggles: [
	                { toggleId: 'smsEnabled', settingsId: 'sms-settings' },
	                { toggleId: 'smsRemindersEnabled', settingsId: 'sms-reminder-settings' }
	            ]
	        };
	
	        // Config for sms-settings.js (Twilio test connection)
	        window.BookedSmsSettings = {
	            testUrl: '{{ actionUrl('booked/cp/settings/test-twilio') }}',
	            csrfToken: '{{ craft.app.request.csrfToken }}',
	            strings: {
	                testing: '{{ "settings.sms.testing"|t('booked') }}',
	                testButton: '{{ "settings.sms.testTwilioButton"|t('booked') }}'
	            }
	        };
	{% endjs %}
