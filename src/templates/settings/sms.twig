                label: 'settings.sms.confirmationTemplate'|t('booked'),
                instructions: 'settings.sms.confirmationTemplateInstructions'|t('booked'),
                id: 'smsConfirmationTemplate',
                name: 'settings[smsConfirmationTemplate]',
                value: settings.smsConfirmationTemplate,
                rows: 3,
                placeholder: 'sms.confirmation'|t('booked')
            }) }}

			{{ forms.textareaField({
                label: 'settings.sms.reminderTemplate'|t('booked'),
                instructions: 'settings.sms.reminderTemplateInstructions'|t('booked'),
                id: 'smsReminderTemplate',
                name: 'settings[smsReminderTemplate]',
                value: settings.smsReminderTemplate,
