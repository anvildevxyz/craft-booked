			{{ forms.selectField({
                label: 'settings.sms.defaultCountryCode'|t('booked'),
                instructions: 'settings.sms.defaultCountryCodeInstructions'|t('booked'),
                id: 'defaultCountryCode',
                name: 'settings[defaultCountryCode]',
                value: settings.defaultCountryCode ?? 'US',
                options: countryOptions
            }) }}

			<div class="field booked-mt-16">
				<div class="heading">
					<label>{{ 'settings.sms.testConnection'|t('booked') }}</label>
					<div class="instructions">
						<p>{{ 'settings.sms.testConnectionInstructions'|t('booked') }}</p>
					</div>
				</div>
				<div class="input">
					<button type="button" id="test-twilio-btn" class="btn">{{ 'settings.sms.testTwilioButton'|t('booked') }}</button>
					<div id="twilio-test-result" class="booked-test-result">
						<pre></pre>
					</div>
				</div>
			</div>

			<hr>

			<h3>{{ 'settings.sms.notificationTypes'|t('booked') }}</h3>

			{{ forms.lightswitchField({
                label: 'settings.sms.enableConfirmations'|t('booked'),
                instructions: 'settings.sms.enableConfirmationsInstructions'|t('booked'),
                id: 'smsConfirmationEnabled',
                name: 'settings[smsConfirmationEnabled]',
                on: settings.smsConfirmationEnabled ?? false
            }) }}

			{{ forms.lightswitchField({
                label: 'settings.sms.enableReminders'|t('booked'),
                instructions: 'settings.sms.enableRemindersInstructions'|t('booked'),
                id: 'smsRemindersEnabled',
                name: 'settings[smsRemindersEnabled]',
                on: settings.smsRemindersEnabled,
                toggle: '#sms-reminder-settings',
            }) }}

			<div id="sms-reminder-settings" class="{% if not settings.smsRemindersEnabled %}hidden{% endif %}">
				{{ forms.textField({
                    label: 'settings.sms.reminderHours'|t('booked'),
                    instructions: 'settings.sms.reminderHoursInstructions'|t('booked'),
                    id: 'smsReminderHoursBefore',
                    name: 'settings[smsReminderHoursBefore]',
                    value: settings.smsReminderHoursBefore,
                    type: 'number',
                    min: 1,
                    max: 168
                }) }}
			</div>

			{{ forms.lightswitchField({
                label: 'settings.sms.enableCancellations'|t('booked'),
                instructions: 'settings.sms.enableCancellationsInstructions'|t('booked'),
                id: 'smsCancellationEnabled',
                name: 'settings[smsCancellationEnabled]',
                on: settings.smsCancellationEnabled ?? false
            }) }}

