{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedSettingsAsset") %}

{% set fullPageForm = true %}
{% set selectedSubnavItem = 'settings' %}
{% set selectedSettingsSubnavItem = 'sms' %}
{% set title = 'settings.sms.title'|t('booked') %}

{% block sidebar %}
	{% include 'booked/settings/_sidebar' %}
{% endblock %}

{% block content %}
	<form method="post" accept-charset="UTF-8" id="settings-form">
		{{ csrfInput() }}
		<input type="hidden" name="action" value="booked/cp/settings/save">
		<input type="hidden" name="tab" value="sms">
		{{ redirectInput('booked/settings/sms') }}

		<h2 class="first">{{ 'settings.sms.title'|t('booked') }}</h2>
		<p class="light">{{ 'settings.sms.description'|t('booked') }}</p>
		<hr>
		{{ forms.lightswitchField({
            label: 'settings.sms.enable'|t('booked'),
            instructions: 'settings.sms.enableInstructions'|t('booked'),
            id: 'smsEnabled',
            name: 'settings[smsEnabled]',
            on: settings.smsEnabled,
            toggle: '#sms-settings',
        }) }}

		<div
			id="sms-settings" class="{% if not settings.smsEnabled %}hidden{% endif %}">
			{# Twilio Configuration - auto-set provider since only Twilio is supported #}
			<input type="hidden" name="settings[smsProvider]" value="twilio">

			<hr>

			<h3>{{ 'settings.sms.twilioConfig'|t('booked') }}</h3>
			<p class="light">{{ 'settings.sms.twilioCredentials'|t('booked') }}
				<a href="https://console.twilio.com" target="_blank">console.twilio.com</a>
			</p>

			{{ forms.textField({
                label: 'settings.sms.accountSid'|t('booked'),
                id: 'twilioAccountSid',
                name: 'settings[twilioAccountSid]',
                value: settings.twilioAccountSid
            }) }}

			{{ forms.passwordField({
                label: 'settings.sms.authToken'|t('booked'),
                id: 'twilioAuthToken',
                name: 'settings[twilioAuthToken]',
                value: settings.twilioAuthToken
            }) }}

			{{ forms.textField({
                label: 'settings.sms.phoneNumber'|t('booked'),
                instructions: 'settings.sms.phoneNumberInstructions'|t('booked'),
                id: 'twilioPhoneNumber',
                name: 'settings[twilioPhoneNumber]',
                value: settings.twilioPhoneNumber,
                placeholder: '+1234567890'
            }) }}

