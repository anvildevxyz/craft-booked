{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedSettingsAsset") %}

{% set fullPageForm = true %}
{% set selectedSubnavItem = 'settings' %}
{% set selectedSettingsSubnavItem = 'booking' %}
{% set title = 'settings.booking.title'|t('booked') %}

{% block sidebar %}
	{% include 'booked/settings/_sidebar' %}
{% endblock %}

{% block content %}
	<form method="post" accept-charset="UTF-8" id="settings-form">
		{{ csrfInput() }}
		<input type="hidden" name="action" value="booked/cp/settings/save">
		<input type="hidden" name="tab" value="booking">
		{{ redirectInput('booked/settings/booking') }}

		<h2 class="heading first">{{ 'settings.booking.title'|t('booked') }}</h2>
		<p class="light">{{ 'settings.booking.description'|t('booked') }}</p>
		<hr>
		{{ forms.textField({
            label: 'settings.booking.softLockDuration'|t('booked'),
            instructions: 'settings.booking.softLockInstructions'|t('booked'),
            id: 'softLockDurationMinutes',
            name: 'settings[softLockDurationMinutes]',
            value: settings.softLockDurationMinutes,
            type: 'number',
            min: 1
        }) }}

		{{ forms.textField({
            label: 'settings.booking.defaultTimeSlotLength'|t('booked'),
            instructions: 'settings.booking.defaultTimeSlotInstructions'|t('booked'),
            id: 'defaultTimeSlotLength',
            name: 'settings[defaultTimeSlotLength]',
            value: settings.defaultTimeSlotLength,
            type: 'number',
            min: 5
        }) }}

		{{ forms.textField({
            label: 'settings.notifications.bookingPageUrl'|t('booked'),
            instructions: 'settings.notifications.bookingPageUrlInstructions'|t('booked'),
            id: 'bookingPageUrl',
            name: 'settings[bookingPageUrl]',
            value: settings.bookingPageUrl,
            type: 'url',
            placeholder: 'https://yoursite.com/booking'
        }) }}

		<hr>
		<h2>{{ 'settings.booking.advancedTitle'|t('booked') }}</h2>

		{{ forms.selectField({
            label: 'settings.booking.mutexDriver'|t('booked'),
            instructions: 'settings.booking.mutexDriverInstructions'|t('booked'),
            id: 'mutexDriver',
            name: 'settings[mutexDriver]',
            value: settings.mutexDriver ?? 'auto',
            options: [
                { label: 'Auto-detect (Recommended)'|t('booked'), value: 'auto' },
                { label: 'File-based (single server)'|t('booked'), value: 'file' },
                { label: 'Database (MySQL GET_LOCK)'|t('booked'), value: 'db' },
                { label: 'Redis (requires yii2-redis)'|t('booked'), value: 'redis' },
            ]
        }) }}
	</form>
{% endblock %}
