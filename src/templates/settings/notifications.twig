{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedSettingsAsset") %}

{% set fullPageForm = true %}
{% set selectedSubnavItem = 'settings' %}
{% set selectedSettingsSubnavItem = 'notifications' %}
{% set title = 'settings.notifications.title'|t('booked') %}

{% block sidebar %}
    {% include 'booked/settings/_sidebar' %}
{% endblock %}

{% block content %}
    <form method="post" accept-charset="UTF-8" id="settings-form">
        {{ csrfInput() }}
        <input type="hidden" name="action" value="booked/cp/settings/save">
        <input type="hidden" name="tab" value="notifications">
        {{ redirectInput('booked/settings/notifications') }}

        <h2 class="first">{{ 'settings.notifications.ownerTitle'|t('booked') }}</h2>
        <p class="light">{{ 'settings.notifications.ownerDescription'|t('booked') }}</p>
        <hr>
        {{ forms.lightswitchField({
            label: 'settings.notifications.enableOwner'|t('booked'),
            instructions: 'settings.notifications.enableOwnerInstructions'|t('booked'),
            id: 'ownerNotificationEnabled',
            name: 'settings[ownerNotificationEnabled]',
            on: settings.ownerNotificationEnabled
        }) }}

        {% set systemEmail = craft.app.projectConfig.get('email.fromEmail') %}
        {% set systemName = craft.app.projectConfig.get('email.fromName') %}

        {{ forms.textField({
            label: 'settings.notifications.ownerEmail'|t('booked'),
            instructions: 'settings.notifications.ownerEmailInstructions'|t('booked'),
            id: 'ownerEmail',
            name: 'settings[ownerEmail]',
            value: settings.ownerEmail,
            type: 'email',
            placeholder: systemEmail ?? 'admin@example.com'
        }) }}

        {{ forms.textField({
            label: 'settings.notifications.ownerName'|t('booked'),
            instructions: 'settings.notifications.ownerNameInstructions'|t('booked'),
            id: 'ownerName',
            name: 'settings[ownerName]',
            value: settings.ownerName,
            placeholder: systemName ?? 'settings.notifications.ownerNamePlaceholder'|t('booked')
        }) }}

        {{ forms.textField({
            label: 'settings.notifications.ownerSubject'|t('booked'),
            instructions: 'settings.notifications.ownerSubjectInstructions'|t('booked'),
            id: 'ownerNotificationSubject',
            name: 'settings[ownerNotificationSubject]',
            value: settings.ownerNotificationSubject,
            placeholder: 'settings.notifications.ownerSubjectDefault'|t('booked')
        }) }}

        {% if craft.app.isMultiSite %}
            {% set seenLanguages = {} %}
            {% set languageOptions = [{label: 'settings.notifications.ownerLanguageDefault'|t('booked', { language: craft.app.sites.primarySite.language }), value: ''}] %}
            {% for site in craft.app.sites.allSites %}
                {% if site.language not in seenLanguages|keys %}
                    {% set locale = craft.app.i18n.getLocaleById(site.language) %}
                    {% set languageOptions = languageOptions|merge([{label: locale.displayName ~ ' (' ~ site.language ~ ')', value: site.language}]) %}
                    {% set seenLanguages = seenLanguages|merge({ (site.language): true }) %}
                {% endif %}
            {% endfor %}
            {{ forms.selectField({
                label: 'settings.notifications.ownerLanguage'|t('booked'),
                instructions: 'settings.notifications.ownerLanguageInstructions'|t('booked'),
                id: 'ownerNotificationLanguage',
                name: 'settings[ownerNotificationLanguage]',
                value: settings.ownerNotificationLanguage,
                options: languageOptions
            }) }}
        {% endif %}

        <hr>

        <h2>{{ 'settings.notifications.customerTitle'|t('booked') }}</h2>
        <p class="light">{{ 'settings.notifications.customerDescription'|t('booked') }}</p>

        {{ forms.textField({
            label: 'settings.notifications.confirmationSubject'|t('booked'),
            instructions: 'settings.notifications.confirmationSubjectInstructions'|t('booked'),
            id: 'bookingConfirmationSubject',
            name: 'settings[bookingConfirmationSubject]',
            value: settings.bookingConfirmationSubject,
            placeholder: 'settings.notifications.confirmationSubjectDefault'|t('booked')
        }) }}

        <hr>

        {{ forms.lightswitchField({
            label: 'settings.notifications.enableReminders'|t('booked'),
            instructions: 'settings.notifications.enableRemindersInstructions'|t('booked'),
            id: 'emailRemindersEnabled',
            name: 'settings[emailRemindersEnabled]',
            on: settings.emailRemindersEnabled,
            toggle: '#reminder-settings'
        }) }}

        <div id="reminder-settings" class="{% if not settings.emailRemindersEnabled %}hidden{% endif %}">
            {{ forms.textField({
                label: 'settings.notifications.reminderSubject'|t('booked'),
                instructions: 'settings.notifications.reminderSubjectInstructions'|t('booked'),
                id: 'reminderEmailSubject',
                name: 'settings[reminderEmailSubject]',
                value: settings.reminderEmailSubject,
                placeholder: 'settings.notifications.reminderSubjectDefault'|t('booked')
            }) }}

            {{ forms.textField({
                label: 'settings.notifications.hoursBefore'|t('booked'),
                instructions: 'settings.notifications.hoursBeforeInstructions'|t('booked'),
                id: 'emailReminderHoursBefore',
                name: 'settings[emailReminderHoursBefore]',
                value: settings.emailReminderHoursBefore,
                type: 'number',
                min: 1,
                max: 168
            }) }}
        </div>

        <hr>

        {{ forms.lightswitchField({
            label: 'settings.notifications.enableCancellation'|t('booked'),
            instructions: 'settings.notifications.enableCancellationInstructions'|t('booked'),
            id: 'sendCancellationEmail',
            name: 'settings[sendCancellationEmail]',
            on: settings.sendCancellationEmail ?? true,
            toggle: '#cancellation-settings'
        }) }}

        <div id="cancellation-settings" class="{% if not (settings.sendCancellationEmail ?? true) %}hidden{% endif %}">
            {{ forms.textField({
                label: 'settings.notifications.cancellationSubject'|t('booked'),
                instructions: 'settings.notifications.cancellationSubjectInstructions'|t('booked'),
                id: 'cancellationEmailSubject',
                name: 'settings[cancellationEmailSubject]',
                value: settings.cancellationEmailSubject,
                placeholder: 'settings.notifications.cancellationSubjectDefault'|t('booked')
            }) }}
        </div>

    </form>

{% endblock %}
