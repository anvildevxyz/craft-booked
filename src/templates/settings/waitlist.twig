{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedSettingsAsset") %}

{% set fullPageForm = true %}
{% set selectedSubnavItem = 'settings' %}
{% set selectedSettingsSubnavItem = 'waitlist' %}
{% set title = 'settings.booking.waitlistTitle'|t('booked') %}

{% block sidebar %}
	{% include 'booked/settings/_sidebar' %}
{% endblock %}

{% block content %}
	<form method="post" accept-charset="UTF-8" id="settings-form">
		{{ csrfInput() }}
		<input type="hidden" name="action" value="booked/cp/settings/save">
		<input type="hidden" name="tab" value="waitlist">
		{{ redirectInput('booked/settings/waitlist') }}

		<h2 class="heading first">{{ 'settings.booking.waitlistTitle'|t('booked') }}</h2>
		<p class="light">{{ 'settings.booking.waitlistDescription'|t('booked') }}</p>
		<hr>

		{{ forms.lightswitchField({
            label: 'settings.booking.enableWaitlist'|t('booked'),
            instructions: 'settings.booking.enableWaitlistInstructions'|t('booked'),
            id: 'enableWaitlist',
            name: 'settings[enableWaitlist]',
            on: settings.enableWaitlist,
            toggle: '#waitlist-settings'
        }) }}

		<div id="waitlist-settings" class="{% if not settings.enableWaitlist %}hidden{% endif %}">
			{{ forms.textField({
                label: 'settings.booking.waitlistExpiration'|t('booked'),
                instructions: 'settings.booking.waitlistExpirationInstructions'|t('booked'),
                id: 'waitlistExpirationDays',
                name: 'settings[waitlistExpirationDays]',
                value: settings.waitlistExpirationDays,
                type: 'number',
                min: 0
            }) }}

			{{ forms.textField({
                label: 'settings.booking.notificationLimit'|t('booked'),
                instructions: 'settings.booking.notificationLimitInstructions'|t('booked'),
                id: 'waitlistNotificationLimit',
                name: 'settings[waitlistNotificationLimit]',
                value: settings.waitlistNotificationLimit,
                type: 'number',
                min: 1
            }) }}

			{{ forms.textField({
                label: 'settings.booking.waitlistConversionMinutes'|t('booked'),
                instructions: 'settings.booking.waitlistConversionMinutesInstructions'|t('booked'),
                id: 'waitlistConversionMinutes',
                name: 'settings[waitlistConversionMinutes]',
                value: settings.waitlistConversionMinutes,
                type: 'number',
                min: 1
            }) }}
		</div>
	</form>
{% endblock %}
