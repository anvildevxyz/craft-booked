{#
 # Frontend Calendar Connect - Success Page
 #
 # This template is shown after an employee successfully connects their calendar.
 # Site owners can override this by creating: templates/booked/calendar/connect-success.twig
 #}

<!DOCTYPE html>
<html lang="{{ craft.app.locale }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title ?? 'calendarInvite.connected'|t('booked') }} | {{ siteName }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            padding: 48px;
            max-width: 480px;
            width: 100%;
            text-align: center;
        }
        
        .icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }
        
        .icon svg {
            width: 40px;
            height: 40px;
            color: white;
        }
        
        h1 {
            font-size: 28px;
            font-weight: 700;
            color: #18181b;
            margin-bottom: 12px;
        }
        
        .subtitle {
            font-size: 18px;
            color: #3f3f46;
            margin-bottom: 24px;
        }
        
        .description {
            font-size: 15px;
            color: #71717a;
            line-height: 1.6;
            margin-bottom: 32px;
        }
        
        .provider-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #f4f4f5;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            color: #3f3f46;
            font-weight: 500;
        }
        
        .close-hint {
            margin-top: 32px;
            font-size: 13px;
            color: #a1a1aa;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        
        <h1>{{ 'calendarInvite.connectedTitle'|t('booked') }}</h1>
        
        <p class="subtitle">{{ 'calendarInvite.successMessage'|t('booked') }}</p>
        
        <p class="description">
            {{ 'calendarInvite.syncExplanation'|t('booked') }}
        </p>
        
        <div class="provider-badge">
            {% if provider == 'google' %}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Google Calendar
            {% elseif provider == 'outlook' %}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M24 7.387v10.478c0 .23-.08.424-.238.583a.793.793 0 01-.584.238h-9.912V6.565h9.912c.23 0 .424.08.584.238.158.16.238.353.238.584z" fill="#0364B8"/>
                    <path d="M24 7.387v10.478c0 .23-.08.424-.238.583a.793.793 0 01-.584.238H9.553V11.67l4.096 2.557a.48.48 0 00.509 0l9.604-5.994c.076-.047.148-.047.238-.047z" fill="#0078D4"/>
                    <path d="M13.266 6.565v12.121h9.912c.23 0 .424-.08.584-.238.158-.159.238-.353.238-.583V7.387c0-.231-.08-.424-.238-.584a.793.793 0 00-.584-.238h-9.912z" fill="#28A8EA"/>
                    <path d="M9.553 5.304v13.383L0 16.13V7.565l9.553-2.26z" fill="#0078D4"/>
                    <path d="M6.991 9.387c-.5-.318-1.091-.477-1.773-.477-.682 0-1.273.159-1.773.477-.5.318-.886.75-1.159 1.295-.273.546-.41 1.16-.41 1.841 0 .682.137 1.296.41 1.841.273.546.659.978 1.159 1.296.5.318 1.091.477 1.773.477.682 0 1.273-.16 1.773-.477.5-.318.886-.75 1.159-1.296.273-.545.41-1.159.41-1.84 0-.683-.137-1.296-.41-1.842-.273-.545-.659-.977-1.159-1.295zm-.637 4.364c-.182.364-.455.545-.818.545-.364 0-.637-.181-.819-.545-.182-.364-.273-.818-.273-1.364 0-.545.091-1 .273-1.363.182-.364.455-.546.819-.546.363 0 .636.182.818.546.182.363.273.818.273 1.363 0 .546-.091 1-.273 1.364z" fill="#fff"/>
                </svg>
                Microsoft Outlook
            {% else %}
                {{ providerName }}
            {% endif %}
        </div>
        
        <p class="close-hint">{{ 'calendarInvite.closeWindow'|t('booked') }}</p>
    </div>
</body>
</html>
