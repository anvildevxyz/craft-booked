{#
 # Frontend Calendar Connect - Error Page
 #
 # This template is shown when calendar connection fails.
 # Site owners can override this by creating: templates/booked/calendar/connect-error.twig
 #}

<!DOCTYPE html>
<html lang="{{ craft.app.locale }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title ?? 'calendarInvite.connectionFailed'|t('booked') }} | {{ siteName }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            padding: 48px;
            max-width: 480px;
            width: 100%;
            text-align: center;
        }
        
        .icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }
        
        .icon svg {
            width: 40px;
            height: 40px;
            color: white;
        }
        
        h1 {
            font-size: 28px;
            font-weight: 700;
            color: #18181b;
            margin-bottom: 12px;
        }
        
        .error-message {
            font-size: 16px;
            color: #3f3f46;
            line-height: 1.6;
            margin-bottom: 32px;
            padding: 16px;
            background: #fef2f2;
            border-radius: 8px;
            border: 1px solid #fecaca;
        }
        
        .suggestions {
            text-align: left;
            margin-bottom: 32px;
        }
        
        .suggestions h2 {
            font-size: 14px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }
        
        .suggestions ul {
            list-style: none;
        }
        
        .suggestions li {
            font-size: 14px;
            color: #52525b;
            padding: 8px 0;
            padding-left: 24px;
            position: relative;
        }
        
        .suggestions li::before {
            content: "→";
            position: absolute;
            left: 0;
            color: #a1a1aa;
        }
        
        .close-hint {
            font-size: 13px;
            color: #a1a1aa;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </div>
        
        <h1>{{ 'calendarInvite.connectionFailed'|t('booked') }}</h1>
        
        <p class="error-message">{{ message }}</p>
        
        <div class="suggestions">
            <h2>{{ 'calendarInvite.whatToTry'|t('booked') }}</h2>
            <ul>
                {% if reason == 'expired' or reason == 'invalid' %}
                    <li>{{ 'calendarInvite.tryNewInvite'|t('booked') }}</li>
                {% elseif reason == 'denied' %}
                    <li>{{ 'calendarInvite.tryClickLink'|t('booked') }}</li>
                {% elseif reason == 'session' %}
                    <li>{{ 'calendarInvite.tryDirectClick'|t('booked') }}</li>
                    <li>{{ 'calendarInvite.tryCookies'|t('booked') }}</li>
                {% else %}
                    <li>{{ 'calendarInvite.tryAgain'|t('booked') }}</li>
                    <li>{{ 'calendarInvite.contactAdmin'|t('booked') }}</li>
                {% endif %}
            </ul>
        </div>
        
        <p class="close-hint">{{ 'calendarInvite.contactSupport'|t('booked') }}</p>
    </div>
</body>
</html>
