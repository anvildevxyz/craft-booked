                        <p class="report-card-desc">{{ "reports.waitlist.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>

            <a href="{{ url('booked/reports/event-attendance') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-pink">🎟</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.eventAttendance.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.eventAttendance.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>
