{% extends "_layouts/cp" %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}

{% set title = "reports.title"|t('booked') %}
{% set selectedSubnavItem = 'reports' %}

{% block content %}
    <div class="reports-index">
        <div class="booked-summary-card summary-blue booked-mb-24">
            <div class="booked-summary-value" style="font-size: 32px;">{{ "reports.title"|t('booked') }}</div>
        </div>

        <div class="booked-grid-auto">
            <a href="{{ url('booked/reports/revenue') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-green">💰</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.revenue.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.revenue.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>

            <a href="{{ url('booked/reports/by-service') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-blue">📊</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.byService.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.byService.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>

            <a href="{{ url('booked/reports/by-employee') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-yellow">👥</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.byEmployee.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.byEmployee.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>

            <a href="{{ url('booked/reports/cancellations') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-red">❌</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.cancellations.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.cancellations.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>

            <a href="{{ url('booked/reports/peak-hours') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-purple">⏰</div>
                    <div>
