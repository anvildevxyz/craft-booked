                </div>
            </a>

            <a href="{{ url('booked/reports/by-location') }}" class="report-card">
                <div class="report-card-content">
                    <div class="report-card-icon bg-teal">📍</div>
                    <div>
                        <h3 class="report-card-title">{{ "reports.byLocation.title"|t('booked') }}</h3>
                        <p class="report-card-desc">{{ "reports.byLocation.description"|t('booked') }}</p>
                    </div>
                </div>
            </a>


            <a href="{{ url('booked/reports/day-of-week') }}" class="report-card">
