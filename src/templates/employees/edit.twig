{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedCpAsset") %}
{% do view.registerAssetBundle("anvildev\\booked\\assetbundles\\BookedEmployeeEditAsset") %}

{% set selectedSubnavItem = 'employees' %}
{% set title = employee.id ? 'employee.edit'|t('booked') : 'employee.new'|t('booked') %}

{% set fullPageForm = true %}

{% set days = {
    1: 'labels.monday'|t('booked'),
    2: 'labels.tuesday'|t('booked'),
    3: 'labels.wednesday'|t('booked'),
    4: 'labels.thursday'|t('booked'),
    5: 'labels.friday'|t('booked'),
    6: 'labels.saturday'|t('booked'),
    7: 'labels.sunday'|t('booked')
} %}

{% block content %}
    <input type="hidden" name="action" value="booked/cp/employees/save">
    {% if employee.id %}
        <input type="hidden" name="elementId" value="{{ employee.id }}">
    {% endif %}

    <div id="fields">
        <div class="field first">
        {{ forms.lightswitchField({
            label: 'Enabled'|t('app'),
            id: 'enabled',
            name: 'enabled',
            on: employee.enabled ?? true
        }) }}
        </div>

        <div class="field">
        {{ forms.textField({
            label: 'Title'|t('app'),
            id: 'title',
            name: 'title',
            value: employee.title,
            required: true,
            autofocus: true,
            errors: employee.getErrors('title')
        }) }}
        </div>

        <div class="field">
        {% set selectedUser = employee.userId ? craft.users.id(employee.userId).one() : null %}
        {{ forms.elementSelectField({
            label: 'labels.user'|t('booked'),
            id: 'userId',
            name: 'userId',
            elementType: 'craft\\elements\\User',
            elements: selectedUser ? [selectedUser] : [],
            limit: 1,
            viewMode: 'large',
            errors: employee.getErrors('userId'),
        }) }}
        </div>

        <div class="field">
        {% set userEmail = selectedUser ? selectedUser.email : null %}
        {{ forms.textField({
            label: 'labels.email'|t('booked'),
            instructions: userEmail
                ? 'employee.emailInstructionsWithUser'|t('booked', { email: userEmail })
                : 'employee.emailInstructionsNoUser'|t('booked'),
            id: 'email',
            name: 'email',
            type: 'email',
            value: employee.email,
            errors: employee.getErrors('email'),
        }) }}
        </div>

        <div class="field">
        {{ forms.elementSelectField({
            label: 'labels.location'|t('booked'),
            id: 'locationId',
            name: 'locationId',
            elementType: 'anvildev\\booked\\elements\\Location',
            elements: employee.locationId and employee.getLocation() ? [employee.getLocation()] : [],
            limit: 1,
            errors: employee.getErrors('locationId'),
        }) }}
        </div>

        {% set assignedServices = [] %}
        {% if employee.id %}
            {% for serviceId in employee.getServiceIds() %}
                {% set service = craft.app.elements.getElementById(serviceId, 'anvildev\\booked\\elements\\Service') %}
                {% if service %}
                    {% set assignedServices = assignedServices|merge([service]) %}
                {% endif %}
            {% endfor %}
        {% endif %}

        <div class="field">
            {{ forms.elementSelectField({
                label: 'labels.services'|t('booked'),
                id: 'services',
                name: 'services',
                elementType: 'anvildev\\booked\\elements\\Service',
                elements: assignedServices,
                limit: null,
                sources: '*',
                errors: employee.getErrors('services'),
            }) }}
        </div>

        <div class="field">
            {{ forms.elementSelectField({
                label: 'employee.managedEmployees'|t('booked'),
                instructions: 'employee.managedEmployeesInstructions'|t('booked'),
                id: 'managedEmployees',
                name: 'managedEmployees',
                elementType: 'anvildev\\booked\\elements\\Employee',
                elements: managedEmployees ?? [],
                limit: null,
            }) }}
        </div>

        <hr>

        <h2>{{ 'labels.schedules'|t('booked') }}</h2>
        {% set assignedSchedules = employee.id ? employee.getSchedules() : [] %}
        <div class="field">
            {{ forms.elementSelectField({
                label: 'employee.assignedSchedules'|t('booked'),
                instructions: 'employee.assignedSchedulesInstructions'|t('booked'),
                id: 'schedules',
                name: 'schedules',
                elementType: 'anvildev\\booked\\elements\\Schedule',
                elements: assignedSchedules,
                limit: null,
                sortable: true,
                sources: '*',
                errors: employee.getErrors('schedules'),
            }) }}
        </div>

        {% if employee.id %}
            <hr>
            <h2>{{ 'employee.calendarSync'|t('booked') }}</h2>
            
            {% set calendarSync = craft.app.plugins.getPlugin('booked').getCalendarSync() %}
            {% set googlePendingInvite = calendarSync.getPendingInvite(employee.id, 'google') %}
            {% set outlookPendingInvite = calendarSync.getPendingInvite(employee.id, 'outlook') %}

            <div class="field">
                <div class="heading">
                    <label>{{ 'employee.googleCalendar'|t('booked') }}</label>
                </div>
                <div class="input">
                    {% if googleConnected %}
                        <span class="status green"></span> {{ 'employee.connected'|t('booked') }}
                        <div class="btngroup" style="margin-top: 8px;">
                            <a href="{{ url('booked/calendar/connect', { employeeId: employee.id, provider: 'google' }) }}" class="btn small">{{ 'employee.reconnect'|t('booked') }}</a>
                            <button type="button" class="btn small calendar-action-btn" data-action="booked/cp/calendar/disconnect" data-employee-id="{{ employee.id }}" data-provider="google">{{ 'employee.disconnect'|t('booked') }}</button>
                        </div>
                    {% else %}
                        <div class="btngroup">
                            <a href="{{ url('booked/calendar/connect', { employeeId: employee.id, provider: 'google' }) }}" class="btn small submit" title="{{ 'employee.connectDirect'|t('booked') }}">{{ 'employee.connect'|t('booked') }}</a>
                            {% if employee.email %}
                                <button type="button" class="btn small calendar-action-btn" data-action="booked/cp/calendar/send-invite" data-employee-id="{{ employee.id }}" data-provider="google" title="{{ 'employee.sendInvite'|t('booked') }}">{{ 'employee.sendInviteBtn'|t('booked') }}</button>
                            {% endif %}
                        </div>
                        {% if googlePendingInvite %}
                            <div class="light" style="margin-top: 8px; font-size: 12px;">
                                <span class="status orange"></span>
                                {{ 'employee.inviteSent'|t('booked', {
                                    email: googlePendingInvite.email,
                                    date: googlePendingInvite.expiresAt|date('short')
                                }) }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            <div class="field">
                <div class="heading">
                    <label>{{ 'employee.microsoftOutlook'|t('booked') }}</label>
                </div>
                <div class="input">
                    {% if outlookConnected %}
                        <span class="status green"></span> {{ 'employee.connected'|t('booked') }}
                        <div class="btngroup" style="margin-top: 8px;">
                            <a href="{{ url('booked/calendar/connect', { employeeId: employee.id, provider: 'outlook' }) }}" class="btn small">{{ 'employee.reconnect'|t('booked') }}</a>
                            <button type="button" class="btn small calendar-action-btn" data-action="booked/cp/calendar/disconnect" data-employee-id="{{ employee.id }}" data-provider="outlook">{{ 'employee.disconnect'|t('booked') }}</button>
                        </div>
                    {% else %}
                        <div class="btngroup">
                            <a href="{{ url('booked/calendar/connect', { employeeId: employee.id, provider: 'outlook' }) }}" class="btn small submit" title="{{ 'employee.connectDirect'|t('booked') }}">{{ 'employee.connect'|t('booked') }}</a>
                            {% if employee.email %}
                                <button type="button" class="btn small calendar-action-btn" data-action="booked/cp/calendar/send-invite" data-employee-id="{{ employee.id }}" data-provider="outlook" title="{{ 'employee.sendInvite'|t('booked') }}">{{ 'employee.sendInviteBtn'|t('booked') }}</button>
                            {% endif %}
                        </div>
                        {% if outlookPendingInvite %}
                            <div class="light" style="margin-top: 8px; font-size: 12px;">
                                <span class="status orange"></span>
                                {{ 'employee.inviteSent'|t('booked', {
                                    email: outlookPendingInvite.email,
                                    date: outlookPendingInvite.expiresAt|date('short')
                                }) }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

{% js %}
window.BookedConfig = window.BookedConfig || {};
window.BookedConfig.assignedUserIds = {{ (assignedUserIds ?? [])|json_encode|raw }};
{% endjs %}

