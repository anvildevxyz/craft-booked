{% extends 'booked/emails/_base' %}

{% set title = 'emails.confirmation.title'|t('booked') %}
{% set headerIcon = '✓' %}
{% set headerColor = '#000000' %}
{% set preheader = 'emails.confirmation.preheader'|t('booked', { date: formattedDateTime }) %}

{% block header %}
<div class="email-header">
    <div style="
        width: 64px;
        height: 64px;
        background: #000000;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    ">
        <svg viewBox="0 0 24 24" style="width: 36px; height: 36px; stroke: white; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; fill: none;">
            <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
    </div>
    <h1 class="header-title">{{ title }}</h1>
    <p class="header-subtitle">{{ siteName }}</p>
</div>
{% endblock %}

{% block content %}
    <p style="font-size: 18px; font-weight: 800; margin-bottom: 12px;">
        {{ 'emails.hello'|t('booked', { name: userName }) }}
    </p>
    <p>
        {{ 'emails.confirmation.thankyou'|t('booked') }}
    </p>

    <div class="highlight-box success">
        <div class="highlight-primary">📅 {{ formattedDateTime }}</div>
        {% if serviceName is defined and serviceName %}
        <div class="highlight-secondary">{{ serviceName }}</div>
        {% endif %}
        {% if variationName is defined and variationName %}
        <div class="highlight-tertiary">{{ variationName }}</div>
        {% endif %}
    </div>

    <div class="section">
        <div class="section-title">{{ 'labels.bookingDetails'|t('booked') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <span class="info-label">{{ 'emails.confirmation.bookingNumber'|t('booked') }}</span>
                <span class="info-value"><span class="badge badge-primary">#{{ bookingId }}</span></span>
            </div>
            <div class="info-row">
                <span class="info-label">{{ 'labels.date'|t('booked') }}</span>
                <span class="info-value">{{ formattedBookingDate }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">{{ 'labels.time'|t('booked') }}</span>
                <span class="info-value">{{ formattedStartTime }} – {{ formattedEndTime }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">{{ 'labels.duration'|t('booked') }}</span>
                <span class="info-value">{{ duration }} {{ 'labels.minutes'|t('booked') }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">{{ 'emails.confirmation.numberOfPeople'|t('booked') }}</span>
                <span class="info-value">{{ quantity }}</span>
            </div>
            {% if employeeName is defined and employeeName %}
            <div class="info-row">
                <span class="info-label">{{ 'labels.staff'|t('booked') }}</span>
                <span class="info-value">{{ employeeName }}</span>
            </div>
            {% endif %}
            {% if locationName is defined and locationName %}
            <div class="info-row">
                <span class="info-label">{{ 'labels.location'|t('booked') }}</span>
                <span class="info-value">{{ locationName }}</span>
            </div>
            {% endif %}
            <div class="info-row">
                <span class="info-label">{{ 'labels.status'|t('booked') }}</span>
                <span class="info-value">{{ status }}</span>
            </div>
        </div>
    </div>

    {% if reservation is defined %}
        {% set reservationExtras = reservation.getExtras() %}
        {% if reservationExtras|length %}
        <div class="section">
            <div class="section-title">{{ 'emails.confirmation.serviceExtras'|t('booked') }}</div>
            <div class="info-grid">
                {% for item in reservationExtras %}
                    {% set extra = item.extra %}
                    {% set qty = item.quantity %}
                    <div class="info-row">
                        <span class="info-label">
                            {{ extra.title }}
                            {% if qty > 1 %}<span style="font-weight: 400;">({{ qty }}×)</span>{% endif %}
                        </span>
                        <span class="info-value">{{ (extra.price * qty)|currency }}</span>
                    </div>
                {% endfor %}
                <div class="info-row" style="border-top: 2px solid #000000; padding-top: 16px; margin-top: 8px;">
                    <span class="info-label">{{ 'emails.confirmation.extrasTotal'|t('booked') }}</span>
                    <span class="info-value">{{ reservation.getExtrasPrice()|currency }}</span>
                </div>
                <div class="info-row" style="border-top: 2px solid #000000; padding-top: 16px; margin-top: 8px;">
                    <span class="info-label" style="font-size: 16px;">{{ 'labels.totalPrice'|t('booked') }}</span>
                    <span class="info-value" style="font-size: 20px;">{{ reservation.getTotalPrice()|currency }}</span>
                </div>
            </div>
        </div>
        {% endif %}
    {% endif %}

    {% if notes is defined and notes %}
    <div class="section">
        <div class="section-title">{{ 'emails.confirmation.yourNotes'|t('booked') }}</div>
        <div style="background-color: #ffffff; border: 2px solid #000000; padding: 20px; color: #000000; font-size: 14px; font-weight: 600;">
            {{ notes }}
        </div>
    </div>
    {% endif %}

    <div class="section">
        <div class="section-title">{{ 'emails.confirmation.contactDetails'|t('booked') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <span class="info-label">{{ 'labels.name'|t('booked') }}</span>
                <span class="info-value">{{ userName }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">{{ 'labels.email'|t('booked') }}</span>
                <span class="info-value">{{ userEmail }}</span>
            </div>
            {% if userPhone is defined and userPhone %}
            <div class="info-row">
                <span class="info-label">{{ 'labels.phone'|t('booked') }}</span>
                <span class="info-value">{{ userPhone }}</span>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="btn-container">
        <a href="{{ managementUrl }}" class="btn btn-primary">{{ 'emails.common.manageBooking'|t('booked') }}</a>
        <a href="{{ icsUrl }}" class="btn btn-secondary">{{ 'account.addToCalendar'|t('booked') }}</a>
        <a href="{{ cancelUrl }}" class="btn btn-secondary">{{ 'account.cancelBooking'|t('booked') }}</a>
    </div>

    {% if isVirtual is defined and isVirtual %}
    <div class="highlight-box" style="border-color: #000000;">
        <div class="highlight-primary">🎥 {{ 'account.virtualMeeting'|t('booked') }}</div>
        <p style="color: #000000; margin: 16px 0; font-weight: 700;">
            {{ 'emails.confirmation.onlineBooking'|t('booked') }}
        </p>
        <a href="{{ virtualMeetingUrl }}" class="btn btn-primary" style="margin: 8px 0;">
            {{ 'emails.common.joinMeeting'|t('booked') }} ({{ virtualMeetingProvider|capitalize }})
        </a>
        {% if virtualMeetingPassword is defined and virtualMeetingPassword %}
        <p style="color: #000000; margin-top: 16px; font-size: 14px; font-weight: 800;">
            <strong>{{ 'labels.password'|t('booked') }}:</strong> {{ virtualMeetingPassword }}
        </p>
        {% endif %}
    </div>
    {% endif %}

    <div class="notice-box">
        <div class="notice-title">📋 {{ 'emails.confirmation.importantInfo'|t('booked') }}</div>
        <ul>
            <li>{{ 'emails.confirmation.keepEmail'|t('booked') }}</li>
            <li>{{ 'emails.common.cancelInAdvance'|t('booked') }}</li>
            <li>{{ 'emails.confirmation.makeChanges'|t('booked') }}</li>
        </ul>
    </div>
{% endblock %}

{% block footerMeta %}
<div class="footer-meta">
    {{ 'emails.confirmation.createdOn'|t('booked') }} {{ dateCreated }}<br>
    {{ 'emails.confirmation.reference'|t('booked') }}: {{ confirmationToken }}
</div>
{% endblock %}
