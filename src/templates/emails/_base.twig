{#
 # Base Email Layout
 #
 # Shared layout for all booking email templates.
 # Black/white design with strong typography
 #
 # Variables:
 # - title: Email title (required)
 # - preheader: Preview text for email clients (optional)
 # - headerIcon: Emoji or icon for header (optional)
 # - headerColor: Primary color for header accents (optional, default: #000000)
 # - siteName: Site name (auto-set)
 #}

{% set headerColor = headerColor ?? '#000000' %}
{% set siteName = siteName ?? craft.app.systemName %}

<!DOCTYPE html>
<html lang="{{ craft.app.language|slice(0, 2) }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{ title }}</title>
    {% if preheader is defined and preheader %}
    <span style="display: none; max-height: 0; overflow: hidden;">{{ preheader }}</span>
    {% endif %}
    <style>
        /* Reset */
        body, table, td, p, a, li, blockquote {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }
        table, td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }
        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }

        /* Base Styles */
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #000000;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
            -webkit-font-smoothing: antialiased;
        }

        .email-wrapper {
            width: 100%;
            background-color: #ffffff;
            padding: 40px 20px;
        }

        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border: 2px solid #000000;
            box-shadow: none;
            overflow: hidden;
        }

        .email-header {
            text-align: center;
            padding: 48px 40px 32px;
            border-bottom: 2px solid #000000;
        }

        .header-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }

        .header-title {
            color: #000000;
            margin: 0 0 8px 0;
            font-size: 28px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.02em;
        }

        .header-subtitle {
            color: #000000;
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin: 0;
        }

        .email-body {
            padding: 48px 40px;
        }

        .email-footer {
            text-align: center;
            padding: 32px 40px 40px;
            background-color: #ffffff;
            border-top: 2px solid #000000;
        }

        /* Typography */
        h1, h2, h3 {
            color: #000000;
            margin: 0 0 24px 0;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.02em;
        }

        p {
            margin: 0 0 20px 0;
            color: #000000;
            font-size: 16px;
            line-height: 1.6;
        }

        a {
            color: #000000;
            text-decoration: underline;
            font-weight: 700;
        }

        /* Sections */
        .section {
            margin-bottom: 32px;
        }

        .section:last-child {
            margin-bottom: 0;
        }

        .section-title {
            font-size: 11px;
            font-weight: 800;
            color: #000000;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 2px solid #000000;
        }

        /* Info Grid */
        .info-grid {
            background-color: #ffffff;
            border: 2px solid #000000;
            padding: 0;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid #000000;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            color: #000000;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .info-value {
            color: #000000;
            font-weight: 800;
            font-size: 14px;
            text-align: right;
        }

        /* Highlight Box */
        .highlight-box {
            background: #ffffff;
            border: 2px solid #000000;
            padding: 32px;
            margin: 32px 0;
            text-align: center;
        }

        .highlight-box.success {
            background: #ffffff;
            border-color: #000000;
        }

        .highlight-box.warning {
            background: #ffffff;
            border-color: #000000;
        }

        .highlight-box.danger {
            background: #ffffff;
            border-color: #000000;
        }

        .highlight-primary {
            font-size: 24px;
            font-weight: 900;
            color: #000000;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: -0.01em;
        }

        .highlight-secondary {
            font-size: 18px;
            color: #000000;
            font-weight: 800;
            margin-top: 8px;
        }

        .highlight-tertiary {
            font-size: 14px;
            color: #000000;
            font-weight: 700;
            margin-top: 8px;
        }

        /* Customer Info Box */
        .customer-box {
            background: #ffffff;
            border: 2px solid #000000;
            padding: 24px;
            margin: 24px 0;
        }

        .customer-box-title {
            color: #000000;
            font-weight: 900;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 2px solid #000000;
        }

        /* Buttons */
        .btn-container {
            text-align: center;
            margin: 32px 0;
        }

        .btn {
            display: inline-block;
            padding: 16px 32px;
            border: 2px solid #000000;
            background: #000000;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 800;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin: 8px;
            transition: all 0.15s;
        }

        .btn-primary {
            background: #000000;
            color: #ffffff !important;
            border-color: #000000;
        }

        .btn-secondary {
            background-color: #ffffff;
            color: #000000 !important;
            border: 2px solid #000000;
        }

        .btn-danger {
            background: #000000;
            color: #ffffff !important;
            border-color: #000000;
        }

        .btn-success {
            background: #000000;
            color: #ffffff !important;
            border-color: #000000;
        }

        /* Notice Box */
        .notice-box {
            background: #ffffff;
            border: 2px solid #000000;
            padding: 24px;
            margin: 32px 0;
        }

        .notice-title {
            color: #000000;
            font-weight: 900;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 2px solid #000000;
        }

        .notice-box ul {
            margin: 0;
            padding-left: 24px;
            color: #000000;
        }

        .notice-box li {
            margin: 12px 0;
            font-size: 14px;
            font-weight: 600;
        }

        /* Badge */
        .badge {
            display: inline-block;
            padding: 6px 12px;
            border: 2px solid #000000;
            background: #000000;
            color: #ffffff;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .badge-primary {
            background: #000000;
            color: #ffffff;
            border-color: #000000;
        }

        .badge-success {
            background: #000000;
            color: #ffffff;
            border-color: #000000;
        }

        .badge-warning {
            background: #000000;
            color: #ffffff;
            border-color: #000000;
        }

        .badge-danger {
            background: #000000;
            color: #ffffff;
            border-color: #000000;
        }

        /* Footer */
        .footer-company {
            font-size: 18px;
            font-weight: 900;
            color: #000000;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }

        .footer-contact {
            color: #000000;
            font-size: 14px;
            font-weight: 700;
            margin: 8px 0;
        }

        .footer-meta {
            color: #000000;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid #000000;
        }

        /* Responsive */
        @media only screen and (max-width: 600px) {
            .email-wrapper {
                padding: 20px 10px;
            }

            .email-header,
            .email-body,
            .email-footer {
                padding-left: 24px;
                padding-right: 24px;
            }

            .header-title {
                font-size: 24px;
            }

            .highlight-primary {
                font-size: 20px;
            }

            .info-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
            }

            .info-value {
                text-align: left;
            }

            .btn {
                display: block;
                margin: 12px 0;
            }
        }
    </style>
</head>
<body>
    <div class="email-wrapper">
        <div class="email-container">
            {% block header %}
            <div class="email-header">
                {% if headerIcon is defined and headerIcon %}
                <div class="header-icon">{{ headerIcon }}</div>
                {% endif %}
                <h1 class="header-title">{{ title }}</h1>
                <p class="header-subtitle">{{ siteName }}</p>
            </div>
            {% endblock %}

            <div class="email-body">
                {% block content %}{% endblock %}
            </div>

            {% block footer %}
            <div class="email-footer">
                {% if ownerName is defined and ownerName %}
                <div class="footer-company">{{ ownerName }}</div>
                {% endif %}
                {% if ownerEmail is defined and ownerEmail %}
                <p class="footer-contact">
                    {{ 'emails.common.questions'|t('booked') }} <a href="mailto:{{ ownerEmail }}">{{ ownerEmail }}</a>
                </p>
                {% endif %}
                {% block footerMeta %}
                <div class="footer-meta">
                    {% if bookingId is defined %}
                    {{ 'element.booking'|t('booked') }} #{{ bookingId }}<br>
                    {% endif %}
                    {% if dateCreated is defined %}
                    {{ 'emails.confirmation.createdOn'|t('booked') }} {{ dateCreated }}
                    {% endif %}
                </div>
                {% endblock %}
            </div>
            {% endblock %}
        </div>
    </div>
</body>
</html>
